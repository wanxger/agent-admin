{
  "$schema": "https://developer.microsoft.com/json-schemas/rush/v5/rush.schema.json",
  "rushVersion": "5.162.0",
  "pnpmVersion": "9.15.9",
  "nodeSupportedVersionRange": ">=22.20.0 <23.0.0",
